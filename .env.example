# Database
DATABASE_URL="postgresql://inventarisatie:geheim@db:5432/inventarisatie?schema=public"
DB_PASSWORD="geheim"

# NextAuth — genereer een sterk secret: openssl rand -base64 32
NEXTAUTH_URL="https://inventory.zepta-nas.nl"
NEXTAUTH_SECRET="verander-dit-naar-een-sterk-random-secret"

# Brevo SMTP
# BREVO_SMTP_USER = het e-mailadres waarmee je bij Brevo bent ingelogd
BREVO_SMTP_USER="jouw@emailadres.nl"
BREVO_SMTP_KEY="xsmtpsib-..."
BREVO_SMTP_PORT="587"         # 587 (standaard), 465 (SSL) of 2525

# Afzendergegevens
EMAIL_FROM="noreply@jouwinkel.nl"
EMAIL_NAAM="WinkelPro"
